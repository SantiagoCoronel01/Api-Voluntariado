@URL = https://web-production-5d34.up.railway.app

###
# Obtener todos los usuarios
GET {{URL}}/traer_usuarios

###
# Crear usuario
POST {{URL}}/nuevo_usuario
Content-Type: application/json

{
    "nombre": "Juan",
    "apellido": "Perez",
    "provincia": "Buenos Aires"
}


###
# Actualizar usuario con id=1
PUT {{URL}}/actualizar_usuario_prueba/1
Content-Type: application/json

{
    "nom": "Juan Actualizado"
}

###
# Eliminar usuario con id=1
DELETE {{URL}}/eliminar_usuario_prueba/3

########################################################################
####################### LINEAS VOLUNTARIADO ############################


#######################  GESTION USUARIOS   ############################

###
# Obtener todos los usuarios
GET {{URL}}/traer_usuarios_voluntariado

###
# Crear usuario
POST {{URL}}/nuevo_usuario_voluntariado
Content-Type: application/json

{
    "nombre": "Santiago",
    "mail": "santiago.coronel@sagradoalcal.edu.ar",
    "clave": "Voluntario01",
    "perfil": "Referente"
}

###
# Actualizar usuario con id
PUT {{URL}}/actualizar_usuario_voluntariado/2
Content-Type: application/json

{
    "nombre": "Juan Actualizado",
    "mail": "Juan@sagradoalcal.edu.ar",
    "perfil": "volountario",
    "clave": "volountario"
}

###
# Eliminar usuario con id
DELETE {{URL}}/eliminar_usuario_voluntariado/2

###
# Activar usuario
PUT {{URL}}/activar_usuario/1

#######################  GESTION ANUNCIOS ############################

###
# Traer anuncios
GET {{URL}}/traer_anuncios

###
# Crear anuncio
POST {{URL}}/nuevo_anuncio
Content-Type: application/json

{
    "titulo": "Colecta de ropa",
    "descripcion": "Traer ropa de invierno",
    "img": "ropa.jpg",
    "fecha_evento": "2026-07-20 17:00:00",
    "tipo_evento": "Solidario",
    "usuario": 1
}

###
# Actualizar anuncio

PUT {{URL}}/actualizar_anuncio/1
Content-Type: application/json

{
    "titulo": "Colecta de alimentos",
    "descripcion": "Traer alimentos no perecederos"
}

###
# Eliminar anuncio

DELETE {{URL}}/eliminar_anuncio/2

########################################################################
####################### GESTIÓN INVENTARIO ##############################

###
# Añadir objeto

POST {{URL}}/nuevo_objeto
Content-Type: application/json

{
    "nombre": "Leche",
    "cantidad": 20
}

###
# Traer inventario

GET {{URL}}/traer_inventario

###
# Actualizar objeto

PUT {{URL}}/actualizar_objeto/1
Content-Type: application/json

{
    "cantidad": 30
}

###
# Eliminar objeto

DELETE {{URL}}/eliminar_objeto/1

